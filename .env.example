# Azure OpenAI
AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_DEPLOYMENT=your_deployment_name
AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Azure SQL Database (Service Principal)
USE_AZURE_SQL=1
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_DATABASE=your_database
AZURE_SQL_SCHEMA=your_schema
AZURE_SQL_TABLE=your_table
AZURE_SQL_CLIENT_ID=your_client_id
AZURE_SQL_CLIENT_SECRET=your_client_secret
AZURE_SQL_TENANT_ID=your_tenant_id
AZURE_SQL_TIMEOUT=30

# Pipeline behaviour (batch size, row limits, labels, etc.) is set in config.yaml — not here.